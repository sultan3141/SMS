<?php

namespace App\Filament\Widgets;

use App\Models\Course;
use Filament\Widgets\ChartWidget;

class StudentsPerCourseChart extends ChartWidget
{
    protected static ?string $heading = 'Students per Course';

    protected function getData(): array
    {
        $courses = Course::withCount('enrollments')->get();
        
        return [
            'datasets' => [
                [
                    'label' => 'Students',
                    'data' => $courses->pluck('enrollments_count'),
                    'backgroundColor' => '#8b5cf6', // Violet
                ],
            ],
            'labels' => $courses->pluck('code'),
        ];
    }

    protected function getType(): string
    {
        return 'bar';
    }
}
